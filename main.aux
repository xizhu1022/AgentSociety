\citation{jakobsson1999proofs}
\citation{dwork1992pricing}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Overall Promotion Workflow. (1)~A consumer broadcasts a sample task when a service need arises. (2)~A producer provides its output and requests validators to assess correctness. (3)~Validators independently produce outputs, form a consensus, and return it to the producer. (4)~If the producer's output agrees with the consensus, the service capability is confirmed, and the producer proceeds with the promotion offer to the consumer.}}{10}{figure.caption.6}\protected@file@percent }
\newlabel{fig:promotion}{{3}{10}{Overall Promotion Workflow. (1)~A consumer broadcasts a sample task when a service need arises. (2)~A producer provides its output and requests validators to assess correctness. (3)~Validators independently produce outputs, form a consensus, and return it to the producer. (4)~If the producer's output agrees with the consensus, the service capability is confirmed, and the producer proceeds with the promotion offer to the consumer}{figure.caption.6}{}}
\newlabel{fig:promotion@cref}{{[figure][3][]3}{[1][9][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Overall Subscription Workflow. (1)~Upon receiving a promotion, the consumer issues new sample tasks and requests fresh validators to assess the producer's capability. (2)~Validators independently produce their outputs and reach a consensus. (3)~The producer provides its own output to the same tasks. (4)~Validators return the consensus result. (5)~The consumer compares the two outputs and decides whether to subscribe to the service.}}{10}{figure.caption.7}\protected@file@percent }
\newlabel{fig:subscription}{{4}{10}{Overall Subscription Workflow. (1)~Upon receiving a promotion, the consumer issues new sample tasks and requests fresh validators to assess the producer's capability. (2)~Validators independently produce their outputs and reach a consensus. (3)~The producer provides its own output to the same tasks. (4)~Validators return the consensus result. (5)~The consumer compares the two outputs and decides whether to subscribe to the service}{figure.caption.7}{}}
\newlabel{fig:subscription@cref}{{[figure][4][]4}{[1][9][]10}{}{}{}}
\newlabel{def:sub_consensus}{{10}{10}{Subscription Consensus}{definition.10}{}}
\newlabel{def:sub_consensus@cref}{{[definition][10][]10}{[1][9][]10}{}{}{}}
