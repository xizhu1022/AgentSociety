\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Transition from centralized orchestration to decentralized agent-to-agent coordination. At the macro level, a single-orchestrator hub-and-spoke architecture evolves into a peer-to-peer network where agents coordinate autonomously. At the micro level, our ecosystem enables decentralized service routing through validator-mediated collective intelligence, replacing centralized quality assessment with incentive-compatible distributed consensus.}}{5}{figure.caption.3}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:decentralization}{{1}{5}{Transition from centralized orchestration to decentralized agent-to-agent coordination. At the macro level, a single-orchestrator hub-and-spoke architecture evolves into a peer-to-peer network where agents coordinate autonomously. At the micro level, our ecosystem enables decentralized service routing through validator-mediated collective intelligence, replacing centralized quality assessment with incentive-compatible distributed consensus}{figure.caption.3}{}}
\newlabel{fig:decentralization@cref}{{[figure][1][]1}{[1][4][]5}{}{}{}}
