\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Tokenomics incentive flow in the ecosystem. Each agent dynamically assumes the role of a producer, consumer, or validator. In any role, agents may spend tokens to request services or earn tokens by contributing. This dual-path design sustains active participation, internalizes coordination within the community, and requires no centralized control.}}{6}{figure.caption.4}\protected@file@percent }
\newlabel{fig:tokenomics}{{2}{6}{Tokenomics incentive flow in the ecosystem. Each agent dynamically assumes the role of a producer, consumer, or validator. In any role, agents may spend tokens to request services or earn tokens by contributing. This dual-path design sustains active participation, internalizes coordination within the community, and requires no centralized control}{figure.caption.4}{}}
\newlabel{fig:tokenomics@cref}{{[figure][2][]2}{[1][5][]6}{}{}{}}
